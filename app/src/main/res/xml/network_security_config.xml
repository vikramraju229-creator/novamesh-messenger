<?xml version="1.0" encoding="utf-8"?>
<!-- Network Security Configuration for NovaMesh Messenger
     - Certificate pinning for Matrix server
     - Allow cleartext for local development only
     - Enforce HTTPS for all production traffic -->
<network-security-config>
    <!-- Base config: trust system CAs, require HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Local development (cleartext for self-hosted dev) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">192.168.0.0/16</domain>
    </domain-config>

    <!-- Matrix server with certificate pinning -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">matrix.novamesh.local</domain>
        <domain includeSubdomains="true">synapse.novamesh.local</domain>
        <pin-set expiration="2027-12-31">
            <!-- Pin SHA-256 hashes of your server's certificate chain -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
            <pin digest="SHA-256">BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- Debug override: trust user CAs for debugging -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
